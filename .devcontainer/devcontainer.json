{
    "name": "IST356",
    "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
    "postCreateCommand": "pip3 install --user -r requirements.txt && pip3 install --user -r requirements-docs.txt && python3 -m playwright install --with-deps chromium",
    "forwardPorts": [8501, 8000],
    "portsAttributes": {
        "8501": { "label": "Streamlit" },
        "8000": { "label": "FastAPI" }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ],
            "settings": {
                "python.testing.pytestEnabled": true,
                "python.defaultInterpreterPath": "/usr/local/bin/python3"
            }
        }
    }
}
